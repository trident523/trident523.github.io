---
interface Props {
  kind: "post" | "message";
  date: Date;
  body?: string;
  author?: string;
  from?: string;
  source?: string;
  audio?: string;
  image?: string;
}
const { kind, date, body, author, from, source, audio, image } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const resolved = (p?: string) =>
  !p ? undefined : /^https?:\/\//.test(p) ? p : `${base}${p.startsWith("/") ? "" : "/"}${p}`;
const audioUrl = resolved(audio);
const imageUrl = resolved(image);
const when = date.toLocaleString(undefined, {
  dateStyle: "medium",
  timeStyle: "short",
});
const label = kind === "post" ? (author ?? "Update") : (from ?? "Anonymous");
---
<article class="card" data-kind={kind}>
  <div class="meta">
    <span class={`kind ${kind}`}>{kind === "post" ? "Update" : "Note"}</span>
    <span>{label}</span>
    {source ? <span> · via {source}</span> : null}
    <span> · {when}</span>
  </div>
  {body ? <p class="body">{body}</p> : null}
  {imageUrl ? <img class="media" src={imageUrl} alt="" loading="lazy" /> : null}
  {audioUrl ? <audio controls preload="none" src={audioUrl}></audio> : null}
</article>
