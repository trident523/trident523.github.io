---
import Layout from "../layouts/Layout.astro";
const workerUrl = import.meta.env.PUBLIC_WORKER_URL ?? "";
---
<Layout title="Admin">
  <p class="meta">
    Post a quick update. Enter your PIN to authorize; it stays in this browser for a short while.
  </p>

  <form id="admin-form" class="card">
    <div class="field">
      <label for="admin-pin">PIN</label>
      <input id="admin-pin" name="pin" type="password" inputmode="numeric" autocomplete="off" required />
    </div>
    <div class="field">
      <label for="admin-body">Update</label>
      <textarea id="admin-body" name="body" placeholder="Write the update…" maxlength="5000"></textarea>
    </div>
    <div class="field">
      <label for="admin-file">Image or audio (optional)</label>
      <input id="admin-file" name="file" type="file" accept="image/*,audio/*" />
    </div>
    <button type="submit">Post</button>
    <div class="status" id="admin-status" aria-live="polite"></div>
  </form>

  <script is:inline define:vars={{ workerUrl }}>
    (function () {
      const form = document.getElementById("admin-form");
      const status = document.getElementById("admin-status");
      const pinInput = document.getElementById("admin-pin");
      try {
        const cached = sessionStorage.getItem("admin-pin");
        if (cached) pinInput.value = cached;
      } catch {}
      if (!form) return;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        status.className = "status";
        status.textContent = "Posting…";
        if (!workerUrl) {
          status.className = "status err";
          status.textContent = "Admin endpoint isn't configured yet.";
          return;
        }
        const fd = new FormData(form);
        const pin = (fd.get("pin") || "").toString();
        const body = (fd.get("body") || "").toString().trim();
        const file = fd.get("file");
        if (!pin) {
          status.className = "status err";
          status.textContent = "PIN required.";
          return;
        }
        if (!body && !(file && file.size)) {
          status.className = "status err";
          status.textContent = "Write something or attach a file.";
          return;
        }
        const payload = new FormData();
        payload.set("pin", pin);
        payload.set("body", body);
        if (file && file.size) payload.set("file", file);
        try {
          const res = await fetch(workerUrl.replace(/\/$/, "") + "/admin/post", {
            method: "POST",
            body: payload,
          });
          if (!res.ok) {
            const text = await res.text();
            throw new Error(text || res.statusText);
          }
          try { sessionStorage.setItem("admin-pin", pin); } catch {}
          status.className = "status ok";
          status.textContent = "Posted. The site will rebuild in about a minute.";
          form.querySelector("#admin-body").value = "";
          form.querySelector("#admin-file").value = "";
        } catch (err) {
          status.className = "status err";
          status.textContent = (err && err.message) ? String(err.message) : "Posting failed.";
        }
      });
    })();
  </script>
</Layout>
